# ==============================================================================
# Repository Core Glue: Git File Exclusions
# ==============================================================================

# --- System & IDE Glues ---
.obsidian
.DS_Store
Thumbs.db
.vscode/
!.vscode/settings.json

# --- Python & Execution Caches ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.ipynb_checkpoints/

# --- Obsidian Workspace & Plugin Glues ---
# Security block for API tokens
.obsidian/plugins/obsidian-git/                          # Prevents git-in-git conflicts if used

# --- Quarto Compilation Artifacts ---
# (Blocks temporary build assets generated by Positron commands)
/_site/
/.qmd_cache/
/.jupyter_cache/
# anywhere else inside your project tree.
.quarto/ 
# It blocks Git from tracking the main .quarto/ build cache directory sitting right alongside your _quarto.yml file.
/.quarto/  
**/*.quarto_ipynb
